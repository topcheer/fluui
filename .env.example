# Fluui LLM Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file!

# API Key (required)
FLUUI_LLM_API_KEY=your-api-key-here

# Base URL (optional, defaults to ZAI)
# ZAI:       https://open.bigmodel.cn/api/coding/paas/v4
# OpenAI:    https://api.openai.com/v1
# DeepSeek:  https://api.deepseek.com/v1
FLUUI_LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# Model (optional, defaults to glm-5.2)
FLUUI_LLM_MODEL=glm-5.2

# System prompt (optional)
FLUUI_LLM_SYSTEM_PROMPT=You are a helpful assistant.
